  "models": {
    "text": {
      "model": "gpt-4o",
      "endpoint": "/v1/chat/completions",
      "quality": 5,
      "cost": 0.05,
      "params": {
        "temperature": 0.7,
        "max_tokens": 8000
      },
      "features": {
        "strong_reasoning": true,
        "multilingual": true
      }
    },
    
    "image": {
      "model": "imagen-4.0-generate-preview-05-20",
      "endpoint": "/api/v1/imagen/generate",
      "quality": 5,
      "cost_per_image": 0.04,
      "params": {
        "aspect_ratio": "16:9",
        "sample_count": 1
      },
      "features": {
        "resolution": "4K",
        "text_rendering": "best"
      }
    },
    
    "video": {
      "model": "kling-v2",
      "endpoint": "/v1/videos/kling/image-to-video",
      "quality": 4,
      "cost_per_video": 0.30,
      "params": {
        "duration": "10s",
        "cfg_scale": 0.5
      },
      "features": {
        "image_to_video": true,
        "digital_human": true,
        "lip_sync": true
      }
    },
    
    "audio": {
      "model": "speech-02-turbo",
      "endpoint": "/v1/audio/speech",
      "quality": 5,
      "cost_per_char": 0.001,
      "params": {
        "voice": "male-qn-jingying",
        "response_format": "mp3"
      },
      "features": {
        "emotion_tags": true,
        "chinese_optimized": true
      }
    },
    
    "music": {
      "model": "suno-custom",
      "endpoint": "/api/v1/suno/custom",
      "quality": 5,
      "cost_per_track": 0.10,
      "params": {
        "tags": ["cinematic", "orchestral"],
        "make_instrumental": true,
        "duration": 90
      }
    }
  },
  
