# =============================================================================
# ComfyUI-UnlimitAI 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填写您的配置
# cp .env.example .env

# =============================================================================
# API配置
# =============================================================================

# UnlimitAI API Key（必需）
UNITED_API_KEY=your_api_key_here

# API基础URL（可选，默认为官方URL）
# UNITED_API_BASE_URL=https://api.unlimitai.com

# API超时时间（秒，默认60）
API_TIMEOUT=60

# 最大重试次数（默认3）
MAX_RETRIES=3

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径（可选）
# LOG_FILE=logs/unlimitai.log

# 是否启用彩色日志（默认true）
LOG_COLORS=true

# =============================================================================
# 默认模型配置
# =============================================================================

# 文本生成模型
DEFAULT_TEXT_MODEL=deepseek-chat

# 图像生成模型
DEFAULT_IMAGE_MODEL=flux.1-schnell

# 视频生成模型
DEFAULT_VIDEO_MODEL=kling-video-v2

# 音频生成模型（TTS）
DEFAULT_AUDIO_MODEL=tts-1

# 音乐生成模型
DEFAULT_MUSIC_MODEL=musicgen

# =============================================================================
# 生成参数配置
# =============================================================================

# 默认图像尺寸
DEFAULT_IMAGE_SIZE=1024x1024

# 默认视频时长（秒）
DEFAULT_VIDEO_DURATION=5.0

# 默认音频采样率
DEFAULT_AUDIO_SAMPLE_RATE=22050

# 默认音乐时长（秒）
DEFAULT_MUSIC_DURATION=30.0

# =============================================================================
# 性能配置
# =============================================================================

# 最大并行请求数
MAX_PARALLEL_REQUESTS=5

# 请求间隔时间（秒，防止频率限制）
REQUEST_INTERVAL=0.5

# 缓存TTL（秒，默认1小时）
CACHE_TTL=3600

# =============================================================================
# 存储配置
# =============================================================================

# 数据存储路径
DATA_DIR=data

# 角色数据库路径
CHARACTER_DB_PATH=data/characters.json

# 场景数据库路径
SCENE_DB_PATH=data/scenes.json

# 项目数据库路径
PROJECT_DB_PATH=data/projects.json

# =============================================================================
# ComfyUI特定配置
# =============================================================================

# ComfyUI输入目录
# COMFYUI_INPUT_DIR=/path/to/comfyui/input

# ComfyUI输出目录
# COMFYUI_OUTPUT_DIR=/path/to/comfyui/output

# ComfyUI临时目录
# COMFYUI_TEMP_DIR=/path/to/comfyui/temp

# =============================================================================
# 开发配置
# =============================================================================

# 调试模式
DEBUG=false

# 开发模式
DEV_MODE=false

# 是否启用性能分析
ENABLE_PROFILING=false
